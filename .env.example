# ════════════════════════════════════════
# TRAVEL AGENCY — SERVER .env Template
# ════════════════════════════════════════
# Copia este archivo como .env y completa los valores
# NO compartas este archivo con valores reales

NODE_ENV=development
PORT=5002

# ── Base de datos ─────────────────────
# Obtén estos valores de tu panel de Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres?sslmode=require

# ── Seguridad ─────────────────────────
# GENERA claves seguras con: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_characters
JWT_EXPIRE=30d
JWT_ADMIN_SECRET=your_admin_secret_here
JWT_ADMIN_EXPIRE=8h
BCRYPT_ROUNDS=12

# ── URLs ──────────────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:5002

# ── Amadeus ───────────────────────────
# Regístrate en https://developers.amadeus.com
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_ENVIRONMENT=test

# ── Kiwi / Tequila ────────────────────
# Regístrate en https://tequila.kiwi.com
KIWI_API_KEY=your_kiwi_api_key
KIWI_BASE_URL=https://tequila.kiwi.com/v2

# ── Stripe ────────────────────────────
# Obtén tus claves de https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Email / SMTP ──────────────────────
# Configura SMTP o usa servicios como SendGrid, Mailgun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Your Name <your_email@gmail.com>

# ── Cloudflare Turnstile ──────────────
# Obtén tus claves de https://www.cloudflare.com/products/turnstile/
TURNSTILE_SECRET=your_turnstile_secret_key

# ── Redis (caché) ─────────────────────
# Instala Redis o usa servicios como Upstash, Redis Cloud
REDIS_URL=redis://localhost:6379
CACHE_TTL_FLIGHTS=300
CACHE_TTL_HOTELS=600

# ── Subida de archivos ────────────────
# Configura Cloudinary, AWS S3, o servicio similar
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
CLOUDINARY_URL=cloudinary://your_key@your_cloud
