# ════════════════════════════════════════
# TRAVEL AGENCY — CLIENT .env Template
# ════════════════════════════════════════
# Copia este archivo como .env y completa los valores
# NO compartas este archivo con valores reales

# API
VITE_API_URL=http://localhost:5002/api/v1

# Stripe (usa solo la clave publicable)
VITE_STRIPE_PK=pk_test_your_publishable_key

# Cloudflare Turnstile (usa solo la clave de sitio)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
